# Локальная разработка: API и WebSocket проксируются через Vite (vite.config.ts)

VITE_WS_ENABLED=true
VITE_SYNC_DEBOUNCE_MS=400

# Production (Docker / nginx): оставьте пустыми — запросы идут на тот же домен (/api, /ws)
# VITE_API_URL=
# VITE_WS_URL=

# Раздельный деплой фронта и бэка на разных доменах:
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com
